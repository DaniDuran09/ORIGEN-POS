{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "ESNext",
    "types": [
      "node"
    ],
    "sourceMap": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "generated/**/*.ts"
  ]
}