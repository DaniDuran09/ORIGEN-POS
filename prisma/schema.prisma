generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// falta presentación y variantes
/// presentación es : el mismo solo azul , rojo , regro

model Product {
  id            Int                   @id @default(autoincrement())
  name          String
  description   String?
  image         String?
  baseUnitId    Int
  baseUnit      Unit                  @relation(fields: [baseUnitId], references: [id])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  presentations ProductPresentation[]
  categories    ProductCategory[]
}

model ProductPresentation {
  id                 Int      @id @default(autoincrement())
  productId          Int
  product            Product  @relation(fields: [productId], references: [id])
  name               String
  sku                String   @unique
  barcode            String?  @unique
  /// How many base units this presentation represents.
  /// Example:
  /// - Box x20  -> 20
  /// - Piece    -> 1
  /// - Sack 50kg -> 50000 (base unit = gram)
  quantityInBaseUnit Decimal  @db.Decimal(12, 2)
  cost               Decimal? @db.Decimal(10, 2)
  price              Decimal  @db.Decimal(10, 2)
  /// If true, the POS can ask the cashier for the quantity to sell.
  /// Example: 350g, 1.25m, 750ml.
  canSellPartial     Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Unit {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  symbol   String    @unique
  products Product[]
}

model Category {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  products ProductCategory[]
}

model ProductCategory {
  productId  Int
  categoryId Int
  product    Product  @relation(fields: [productId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
}
